# Environment Variables Example
# Copy this file to .env and fill in your values

# Supabase Configuration (Required for database features)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google AI API Key (Required for PDF summarization)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Picovoice Access Key (Optional - for hotword detection)
# Get your key from: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_key

# OpenAI API Key (Optional - alternative AI provider)
OPENAI_API_KEY=your_openai_api_key
